# ================================
# StudentBuddy Bot Configuration
# ================================

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# API Token для расписания (получить у администратора API)
SCHEDULE_API_TOKEN=your_schedule_api_token_here

# ================================
# Production Settings (optional)
# ================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Database path (по умолчанию: studentbuddy.db)
DATABASE_PATH=studentbuddy.db

# Persistence file path (по умолчанию: data/studentbuddy_data.pickle)
PERSISTENCE_FILE=data/studentbuddy_data.pickle

# ================================
# Advanced Settings (optional)
# ================================

# Enable debug mode (не использовать в production!)
# DEBUG=false

# Timezone (по умолчанию: Europe/Moscow)
# TZ=Europe/Moscow

# Rate limiting (запросов в минуту на пользователя)
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW=60

# Cache TTL (время жизни кэша в секундах)
# CACHE_TTL=300

# TTL кэша расписания (request coalescing), секунды (по умолчанию: 600 = 10 минут)
SCHEDULE_CACHE_TTL=600

# Redis для кэша расписания (опционально). Локально: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# ================================
# Monitoring (optional)
# ================================

# Sentry DSN для мониторинга ошибок
# SENTRY_DSN=your_sentry_dsn_here

# Metrics endpoint
# METRICS_ENABLED=false
# METRICS_PORT=9090
